# Use port 3307 to avoid conflict with local MySQL on 3306
DATABASE_URL="mysql://root:password@localhost:3307/mirrorshop"

# JWT secret for auth tokens (use a strong random value in production)
JWT_SECRET="your-secret-key-change-in-production"

# Brevo (Phase 3 - order emails)
BREVO_API_KEY="xkeysib-your-api-key"
BREVO_FROM_EMAIL="orders@yourdomain.com"
ADMIN_ORDER_EMAIL="admin@yourdomain.com"
