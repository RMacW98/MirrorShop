generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Mirror {
  id          String   @id @default(cuid())
  name        String
  type        String   // wall, floor, vanity, decorative
  price       Float
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
}
